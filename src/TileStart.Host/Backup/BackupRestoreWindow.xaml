<Window x:Class="TileStart.Host.Backup.BackupRestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="备份与恢复"
        Width="660"
        MaxHeight="760"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#1F1F1F"
        Foreground="#F2F2F2"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="12"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Grayscale">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42"
                                  CornerRadius="0"
                                  GlassFrameThickness="0"
                                  ResizeBorderThickness="0"
                                  UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#262626" />
        <SolidColorBrush x:Key="CardBorder" Color="#404040" />
        <SolidColorBrush x:Key="MutedText" Color="#B8B8B8" />

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#343434" />
            <Setter Property="BorderBrush" Value="#606060" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#D23888" />
            <Setter Property="BorderBrush" Value="#D23888" />
        </Style>

        <Style x:Key="OptionCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#F2F2F2" />
        </Style>

        <Style x:Key="BackupExpanderStyle"
               TargetType="Expander"
               BasedOn="{StaticResource TileStartDarkExpanderStyle}">
            <Setter Property="Margin" Value="0,16,0,0" />
            <Setter Property="Background" Value="#242424" />
            <Setter Property="BorderBrush" Value="#404040" />
        </Style>
    </Window.Resources>

    <Border Background="#1F1F1F" BorderBrush="#454545" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="54" />
            </Grid.RowDefinitions>

            <Grid Background="#252525">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Margin="0,0,9,0"
                               VerticalAlignment="Center"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Text="&#xE74E;" />
                    <TextBlock VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="备份与恢复" />
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource TileStartTitleBarCloseButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        IsCancel="True"
                        Content="&#xE8BB;" />
            </Grid>

            <StackPanel Grid.Row="1" Margin="26,22,26,20">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="保护你的 TileStart" />
                <TextBlock Margin="0,5,0,0"
                           Foreground="{StaticResource MutedText}"
                           TextWrapping="Wrap"
                           Text="一键保存布局、应用、偏好与图标资源；需要时也可以精确选择。" />

                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="18"
                            Background="{StaticResource CardBackground}"
                            BorderBrush="{StaticResource CardBorder}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="20"
                                       Foreground="#E85A9E"
                                       Text="&#xE74E;" />
                            <TextBlock Grid.Row="1"
                                       Margin="0,12,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="创建完整备份" />
                            <TextBlock Grid.Row="2"
                                       Margin="0,5,0,16"
                                       MinHeight="36"
                                       Foreground="{StaticResource MutedText}"
                                       TextWrapping="Wrap"
                                       Text="生成可迁移的单文件备份，外部图片也会一并收集。" />
                            <Button x:Name="QuickBackupButton"
                                    Grid.Row="3"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="QuickBackup_Click"
                                    Content="立即备份" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="18"
                            Background="{StaticResource CardBackground}"
                            BorderBrush="{StaticResource CardBorder}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="20"
                                       Foreground="#E85A9E"
                                       Text="&#xE777;" />
                            <TextBlock Grid.Row="1"
                                       Margin="0,12,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="恢复完整备份" />
                            <TextBlock Grid.Row="2"
                                       Margin="0,5,0,16"
                                       MinHeight="36"
                                       Foreground="{StaticResource MutedText}"
                                       TextWrapping="Wrap"
                                       Text="恢复前自动保存当前状态，完成后重新启动 TileStart。" />
                            <Button x:Name="QuickRestoreButton"
                                    Grid.Row="3"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource BaseButtonStyle}"
                                    Click="QuickRestore_Click"
                                    Content="选择备份文件" />
                        </Grid>
                    </Border>
                </Grid>

                <Expander Style="{StaticResource BackupExpanderStyle}"
                          Header="自定义备份内容">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,10"
                                   Foreground="{StaticResource MutedText}"
                                   Text="只备份或恢复勾选的类别。"
                                   TextWrapping="Wrap" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <CheckBox x:Name="LayoutBox"
                                          Style="{StaticResource OptionCheckBoxStyle}"
                                          IsChecked="True"
                                          Content="磁贴布局、分组与外观" />
                                <CheckBox x:Name="CustomAppsBox"
                                          Style="{StaticResource OptionCheckBoxStyle}"
                                          IsChecked="True"
                                          Content="手动添加的应用列表" />
                                <CheckBox x:Name="VisibilityBox"
                                          Style="{StaticResource OptionCheckBoxStyle}"
                                          IsChecked="True"
                                          Content="隐藏和显示的应用状态" />
                                <CheckBox x:Name="PreferencesBox"
                                          Style="{StaticResource OptionCheckBoxStyle}"
                                          IsChecked="True"
                                          Content="窗口尺寸与导航偏好" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <CheckBox x:Name="ManagedIconsBox"
                                          Style="{StaticResource OptionCheckBoxStyle}"
                                          IsChecked="True"
                                          Content="网络图标与 SVG" />
                                <CheckBox x:Name="ExternalVisualsBox"
                                          Style="{StaticResource OptionCheckBoxStyle}"
                                          IsChecked="True"
                                          Content="外部图标与背景图片" />
                                <CheckBox x:Name="TaskbarShortcutsBox"
                                          Style="{StaticResource OptionCheckBoxStyle}"
                                          Content="任务栏辅助快捷方式" />
                            </StackPanel>
                        </Grid>
                        <Border Margin="0,12,0,14"
                                Padding="11,9"
                                Background="#202020"
                                BorderBrush="#383838"
                                BorderThickness="1">
                            <TextBlock Foreground="#AFAFAF"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Text="日志和旧备份始终排除。恢复前会自动创建安全快照。" />
                        </Border>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button Margin="0,0,10,0"
                                    Style="{StaticResource BaseButtonStyle}"
                                    Click="CustomRestore_Click"
                                    Content="按选择恢复" />
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Click="CustomBackup_Click"
                                    Content="按选择备份" />
                        </StackPanel>
                    </StackPanel>
                </Expander>
            </StackPanel>

            <Border Grid.Row="2"
                    Padding="20,9"
                    Background="#252525"
                    BorderBrush="#383838"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Margin="0,0,8,0" Fill="#69C56D" />
                        <TextBlock x:Name="StatusText"
                                   VerticalAlignment="Center"
                                   Foreground="#C8C8C8"
                                   Text="就绪" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="78"
                            Height="32"
                            Style="{StaticResource BaseButtonStyle}"
                            IsCancel="True"
                            Content="关闭" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
