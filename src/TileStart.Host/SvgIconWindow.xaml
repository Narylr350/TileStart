<Window x:Class="TileStart.Host.SvgIconWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SVG 图标"
        Width="660"
        Height="500"
        MinWidth="580"
        MinHeight="430"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="#1F1F1F"
        Foreground="White"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="12"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#333333" />
            <Setter Property="BorderBrush" Value="#686868" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Border BorderBrush="#454545" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>
            <Grid Background="#252525" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="44" />
                </Grid.ColumnDefinitions>
                <TextBlock Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="SVG 源码图标" />
                <Button Grid.Column="1"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        IsCancel="True"
                        Content="&#xE8BB;" />
            </Grid>

            <Grid Grid.Row="1" Margin="20,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock FontSize="13" FontWeight="SemiBold" Text="SVG 代码" />
                <TextBox x:Name="SourceBox"
                         Grid.Row="1"
                         Margin="0,8,18,0"
                         Padding="10"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Foreground="White"
                         Background="#161616"
                         BorderBrush="#565656"
                         BorderThickness="1"
                         CaretBrush="White"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="11"
                         TextWrapping="NoWrap" />
                <Button Grid.Row="2"
                        Width="96"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Left"
                        Background="#0067C0"
                        BorderBrush="#1683D8"
                        Content="验证并预览"
                        Click="Preview_Click" />

                <StackPanel Grid.Column="1" Grid.RowSpan="3">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="预览" />
                    <Border Height="160"
                            Margin="0,8,0,0"
                            Background="#161616"
                            BorderBrush="#4A4A4A"
                            BorderThickness="1">
                        <Image x:Name="PreviewImage"
                               Margin="24"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Stretch="Uniform" />
                    </Border>
                    <TextBlock x:Name="StatusText"
                               Margin="0,12,0,0"
                               Foreground="#B8B8B8"
                               Text="仅允许单个 SVG 根元素，不允许脚本、DOCTYPE 或外部资源。"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Padding="18,12"
                    Background="#252525"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,1,0,0">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Width="76" Margin="0,0,10,0" IsCancel="True" Content="取消" />
                    <Button x:Name="ConfirmButton"
                            Width="76"
                            Background="#0067C0"
                            BorderBrush="#1683D8"
                            IsEnabled="False"
                            IsDefault="True"
                            Content="使用"
                            Click="Confirm_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
