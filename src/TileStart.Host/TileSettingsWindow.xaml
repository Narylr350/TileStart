<Window x:Class="TileStart.Host.TileSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TileStart.Host"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="磁贴设置"
        Width="520"
        Height="680"
        MinWidth="480"
        MinHeight="560"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="#1F1F1F"
        Foreground="#F2F2F2"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="12"
        FontWeight="Normal"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextHintingMode="Fixed"
        TextOptions.TextRenderingMode="Grayscale">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="ControlBackground" Color="#2B2B2B" />
        <SolidColorBrush x:Key="ControlReadOnlyBackground" Color="#252525" />
        <SolidColorBrush x:Key="ControlBorder" Color="#686868" />
        <SolidColorBrush x:Key="ControlBorderHover" Color="#A0A0A0" />
        <SolidColorBrush x:Key="HoverBackground" Color="#3B3B3B" />
        <SolidColorBrush x:Key="PressedBackground" Color="#484848" />
        <SolidColorBrush x:Key="MutedText" Color="#B8B8B8" />
        <SolidColorBrush x:Key="Divider" Color="#3A3A3A" />

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="#F0F0F0" />
        </Style>

        <Style x:Key="FieldHintStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,5,0,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource MutedText}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource ControlBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="SelectionBrush" Value="{x:Static local:Win10Theme.ContextMenuHighlightBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Focusable="False" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{StaticResource ControlBorderHover}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="{x:Static local:Win10Theme.ContextMenuHighlightBrush}" />
                                <Setter TargetName="TextBoxBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource MutedText}" />
                                <Setter Property="Background" Value="{StaticResource ControlReadOnlyBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#333333" />
            <Setter Property="BorderBrush" Value="#777777" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource HoverBackground}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource ControlBorderHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PressedBackground}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{x:Static local:Win10Theme.ContextMenuHighlightBrush}" />
            <Setter Property="BorderBrush" Value="{x:Static local:Win10Theme.ContextMenuHighlightBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.75" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Foreground" Value="#FF8A91" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A2528" />
                    <Setter Property="BorderBrush" Value="#C85A61" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TitleButtonBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TitleButtonBorder" Property="Background" Value="#C42B1C" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TitleButtonBorder" Property="Background" Value="#A52317" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F0F0F0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="CheckBorder"
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,9,0"
                                    Background="{StaticResource ControlBackground}"
                                    BorderBrush="{StaticResource ControlBorder}"
                                    BorderThickness="1">
                                <TextBlock x:Name="CheckGlyph"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="11"
                                           Text="&#xE73E;"
                                           Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource ControlBorderHover}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="{x:Static local:Win10Theme.ContextMenuHighlightBrush}" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{x:Static local:Win10Theme.ContextMenuHighlightBrush}" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#232323" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{x:Static local:Win10Theme.ContextMenuHighlightBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource ControlBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <ContentPresenter Margin="10,0,36,0"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                    <TextBlock Margin="0,0,12,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="9"
                                               Text="&#xE70D;" />
                                    <ToggleButton Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="None">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="240"
                                        Padding="0,4"
                                        Background="#232323"
                                        BorderBrush="#171717"
                                        BorderThickness="1">
                                    <ScrollViewer CanContentScroll="True">
                                        <StackPanel IsItemsHost="True" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource ControlBorderHover}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{x:Static local:Win10Theme.ContextMenuHighlightBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="24" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" VerticalAlignment="Center" Background="{x:Static local:Win10Theme.ContextMenuHighlightBrush}" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="12" Height="20" Background="White">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="#8A8A8A" BorderThickness="1" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" VerticalAlignment="Center" Background="#666666" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogVerticalScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="6" />
            <Setter Property="Margin" Value="0,2,2,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="ScrollThumb"
                                           Width="2"
                                           MinHeight="24"
                                           HorizontalAlignment="Right"
                                           Background="#70FFFFFF"
                                           Opacity="0.72">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ScrollThumb" Property="Width" Value="6" />
                                <Setter TargetName="ScrollThumb" Property="Opacity" Value="1" />
                                <Setter TargetName="ScrollThumb" Property="Background" Value="#A8FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1F1F1F" BorderBrush="#454545" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>

            <Grid Background="#252525">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Margin="0,0,9,0"
                               VerticalAlignment="Center"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Text="&#xE713;" />
                    <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Text="磁贴设置" />
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource TitleBarButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        IsCancel="True"
                        Content="&#xE8BB;" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          Margin="22,18,14,18"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource DialogVerticalScrollBarStyle}" />
                </ScrollViewer.Resources>
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="基本信息" />
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="名称" />
                    <TextBox x:Name="NameBox" />

                    <Border Height="1" Margin="0,22,0,16" Background="{StaticResource Divider}" />
                    <StackPanel x:Name="LaunchSection">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="启动" />
                        <StackPanel x:Name="TargetPanel">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="启动目标" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TargetBox" />
                                <Button x:Name="BrowseTargetButton"
                                        Grid.Column="1"
                                        Width="76"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource DialogButtonStyle}"
                                        Content="浏览…"
                                        Click="BrowseTarget_Click" />
                            </Grid>
                            <TextBlock x:Name="TargetHint"
                                       Style="{StaticResource FieldHintStyle}"
                                       Text="固定来源的启动目标为只读；新建命令磁贴可以直接修改。"
                                       Visibility="Collapsed" />
                        </StackPanel>

                        <TextBlock Margin="0,14,0,5" Style="{StaticResource FieldLabelStyle}" Text="启动参数" />
                        <TextBox x:Name="ArgumentsBox" />

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="工作目录" />
                                <TextBox x:Name="WorkingDirectoryBox" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Width="76"
                                    Margin="10,17,0,0"
                                    Style="{StaticResource DialogButtonStyle}"
                                    Content="浏览…"
                                    Click="BrowseWorkingDirectory_Click" />
                        </Grid>

                        <CheckBox x:Name="RunAsAdministratorBox" Margin="0,16,0,0" Content="以管理员身份运行" />
                    </StackPanel>

                    <Border Height="1" Margin="0,22,0,16" Background="{StaticResource Divider}" />
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="外观" />

                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="自定义图标来源" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="IconPathBox" />
                        <Button Grid.Column="1"
                                Width="76"
                                Margin="10,0,0,0"
                                Style="{StaticResource DialogButtonStyle}"
                                Content="浏览…"
                                Click="BrowseIcon_Click" />
                        <Button Grid.Column="2"
                                Width="58"
                                Margin="8,0,0,0"
                                Style="{StaticResource DialogButtonStyle}"
                                Content="清除"
                                Click="ClearIcon_Click" />
                    </Grid>

                    <TextBlock Margin="0,14,0,5" Style="{StaticResource FieldLabelStyle}" Text="背景图片" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="BackgroundImagePathBox" />
                        <Button Grid.Column="1"
                                Width="76"
                                Margin="10,0,0,0"
                                Style="{StaticResource DialogButtonStyle}"
                                Content="浏览…"
                                Click="BrowseBackgroundImage_Click" />
                        <Button Grid.Column="2"
                                Width="58"
                                Margin="8,0,0,0"
                                Style="{StaticResource DialogButtonStyle}"
                                Content="清除"
                                Click="ClearBackgroundImage_Click" />
                    </Grid>

                    <TextBlock Margin="0,14,0,5" Style="{StaticResource FieldLabelStyle}" Text="背景颜色" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="BackgroundColorPreview"
                                Width="18"
                                Height="18"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                BorderBrush="#8A8A8A"
                                BorderThickness="1" />
                        <TextBox x:Name="BackgroundColorBox"
                                 Grid.Column="1"
                                 TextChanged="BackgroundColorBox_TextChanged" />
                        <Button Grid.Column="2"
                                Width="76"
                                Margin="10,0,0,0"
                                Style="{StaticResource DialogButtonStyle}"
                                Content="选择…"
                                Click="ChooseBackgroundColor_Click" />
                    </Grid>

                    <TextBlock Margin="0,14,0,5" Style="{StaticResource FieldLabelStyle}" Text="文字颜色" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="ForegroundColorPreview"
                                Width="18"
                                Height="18"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                BorderBrush="#8A8A8A"
                                BorderThickness="1" />
                        <TextBox x:Name="ForegroundColorBox"
                                 Grid.Column="1"
                                 TextChanged="ForegroundColorBox_TextChanged" />
                        <Button Grid.Column="2"
                                Width="76"
                                Margin="10,0,0,0"
                                Style="{StaticResource DialogButtonStyle}"
                                Content="选择…"
                                Click="ChooseForegroundColor_Click" />
                    </Grid>

                    <CheckBox x:Name="ShowTitleBox" Margin="0,16,0,0" Content="显示磁贴标题" />

                    <Grid Margin="0,18,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="图标大小" />
                        <TextBlock Grid.Column="1"
                                   Foreground="{StaticResource MutedText}"
                                   Text="{Binding Value, ElementName=IconSizeBox, StringFormat={}{0:0} DIP}" />
                    </Grid>
                    <Slider x:Name="IconSizeBox"
                            Minimum="16"
                            Maximum="96"
                            TickFrequency="8"
                            IsSnapToTickEnabled="True" />

                    <TextBlock Margin="0,16,0,5" Style="{StaticResource FieldLabelStyle}" Text="图标位置" />
                    <ComboBox x:Name="IconPositionBox" SelectedValuePath="Tag">
                        <ComboBoxItem Content="居中" Tag="Center" />
                        <ComboBoxItem Content="左上" Tag="TopLeft" />
                        <ComboBoxItem Content="右上" Tag="TopRight" />
                        <ComboBoxItem Content="左下" Tag="BottomLeft" />
                        <ComboBoxItem Content="右下" Tag="BottomRight" />
                    </ComboBox>

                    <TextBlock Margin="0,16,0,5" Style="{StaticResource FieldLabelStyle}" Text="磁贴尺寸" />
                    <ComboBox x:Name="SizeBox" SelectedValuePath="Tag">
                        <ComboBoxItem Content="小（1×1）" Tag="Small" />
                        <ComboBoxItem Content="中（2×2）" Tag="Medium" />
                        <ComboBoxItem Content="宽（4×2）" Tag="Wide" />
                        <ComboBoxItem Content="大（4×4）" Tag="Large" />
                    </ComboBox>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Padding="20,12"
                    Background="#252525"
                    BorderBrush="{StaticResource Divider}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="UnpinButton"
                            MinWidth="92"
                            Style="{StaticResource DangerButtonStyle}"
                            Content="取消固定"
                            Click="Unpin_Click" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Width="76"
                                Margin="0,0,10,0"
                                Style="{StaticResource DialogButtonStyle}"
                                IsCancel="True"
                                Content="取消" />
                        <Button Width="76"
                                Style="{StaticResource PrimaryButtonStyle}"
                                IsDefault="True"
                                Content="保存"
                                Click="Save_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
