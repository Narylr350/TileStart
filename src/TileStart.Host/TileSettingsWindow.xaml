<Window x:Class="TileStart.Host.TileSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="磁贴设置"
        Width="520"
        Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#202020"
        Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,6" Text="名称" />
        <TextBox x:Name="NameBox" Grid.Row="1" Height="30" Padding="6,3" />

        <TextBlock Grid.Row="2" Margin="0,14,0,6" Text="启动参数" />
        <TextBox x:Name="ArgumentsBox" Grid.Row="3" Height="30" Padding="6,3" />

        <Grid Grid.Row="4" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Margin="0,0,0,6" Text="工作目录" />
                <TextBox x:Name="WorkingDirectoryBox" Height="30" Padding="6,3" />
            </StackPanel>
            <Button Grid.Column="1" Width="72" Height="30" Margin="8,22,0,0" Content="浏览…" Click="BrowseWorkingDirectory_Click" />
        </Grid>

        <Grid Grid.Row="5" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Margin="0,0,0,6" Text="自定义图标来源" />
                <TextBox x:Name="IconPathBox" Height="30" Padding="6,3" />
            </StackPanel>
            <Button Grid.Column="1" Width="72" Height="30" Margin="8,22,0,0" Content="浏览…" Click="BrowseIcon_Click" />
        </Grid>

        <StackPanel Grid.Row="6" Margin="0,16,0,0">
            <TextBlock Margin="0,0,0,6" Text="磁贴尺寸" />
            <ComboBox x:Name="SizeBox" Height="30" SelectedValuePath="Tag">
                <ComboBoxItem Content="小（1×1）" Tag="Small" />
                <ComboBoxItem Content="中（2×2）" Tag="Medium" />
                <ComboBoxItem Content="宽（4×2）" Tag="Wide" />
                <ComboBoxItem Content="大（4×4）" Tag="Large" />
            </ComboBox>
            <CheckBox x:Name="RunAsAdministratorBox" Margin="0,16,0,0" Content="以管理员身份运行" />
        </StackPanel>

        <StackPanel Grid.Row="7" Margin="0,20,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Width="88" Height="32" Margin="0,0,8,0" Content="取消固定" Click="Unpin_Click" />
            <Button Width="72" Height="32" Margin="0,0,8,0" IsCancel="True" Content="取消" />
            <Button Width="72" Height="32" IsDefault="True" Content="保存" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
