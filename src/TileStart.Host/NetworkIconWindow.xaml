<Window x:Class="TileStart.Host.NetworkIconWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="网络图标"
        Width="500"
        Height="330"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="#1F1F1F"
        Foreground="White"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="12"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2B2B2B" />
            <Setter Property="BorderBrush" Value="#686868" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#333333" />
            <Setter Property="BorderBrush" Value="#686868" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Border BorderBrush="#454545" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>
            <Grid Background="#252525" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="44" />
                </Grid.ColumnDefinitions>
                <TextBlock Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="从网络获取图标" />
                <Button Grid.Column="1"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        IsCancel="True"
                        Content="&#xE8BB;" />
            </Grid>

            <Grid Grid.Row="1" Margin="22,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="72"
                        Height="72"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="#161616"
                        BorderBrush="#4A4A4A"
                        BorderThickness="1">
                    <Image x:Name="PreviewImage"
                           Margin="8"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="Uniform" />
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="图片地址" />
                    <TextBox x:Name="UrlBox" Margin="0,8,0,0" />
                    <Button x:Name="DownloadButton"
                            Width="96"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Left"
                            Background="#0067C0"
                            BorderBrush="#1683D8"
                            Content="下载并预览"
                            Click="Download_Click" />
                    <TextBlock x:Name="StatusText"
                               Margin="0,10,0,0"
                               Foreground="#B8B8B8"
                               Text="支持 PNG、JPEG、BMP、GIF、ICO 和 SVG，最大 5 MB。"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Padding="18,12"
                    Background="#252525"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,1,0,0">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Width="76" Margin="0,0,10,0" IsCancel="True" Content="取消" />
                    <Button x:Name="ConfirmButton"
                            Width="76"
                            Background="#0067C0"
                            BorderBrush="#1683D8"
                            IsEnabled="False"
                            IsDefault="True"
                            Content="使用"
                            Click="Confirm_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
