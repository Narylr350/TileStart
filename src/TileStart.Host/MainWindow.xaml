<Window x:Class="TileStart.Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:TileStart.Host"
        Title="TileStart"
        Width="1252"
        Height="768"
        MinWidth="680"
        MinHeight="480"
        Background="#01000000"
        FontFamily="Segoe UI"
        FontSize="14"
        Foreground="White"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        Topmost="True"
        UseLayoutRounding="True"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewTextInput="Window_PreviewTextInput">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="MenuBackground" Color="#CC202020" />
        <SolidColorBrush x:Key="HoverBackground" Color="#22FFFFFF" />
        <SolidColorBrush x:Key="PressedBackground" Color="#32FFFFFF" />
        <SolidColorBrush x:Key="TileBackground" Color="#3A3A3A" />
        <SolidColorBrush x:Key="SubtleText" Color="#D9FFFFFF" />

        <Style x:Key="RailButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Background" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Background" Property="Background" Value="{StaticResource HoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Background" Property="Background" Value="{StaticResource PressedBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppRowStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,0,6,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Background" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Background" Property="Background" Value="{StaticResource HoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Background" Property="Background" Value="{StaticResource PressedBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TileStyle" TargetType="Button">
            <Setter Property="Padding" Value="8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource TileBackground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TileBorder"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileBorder" Property="Background" Value="#494949" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TileBorder" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LetterHeaderStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,0,0,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Background" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Background" Property="Background" Value="{StaticResource HoverBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AlphabetButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Background" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Background" Property="Background" Value="{StaticResource HoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.28" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="AppEntryTemplate">
            <StackPanel>
                <Button Style="{StaticResource AppRowStyle}" Tag="{Binding}" Click="AppButton_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                        </Grid.ColumnDefinitions>
                        <Grid Width="24" Height="24" HorizontalAlignment="Left">
                            <Border Background="#343434" />
                            <TextBlock x:Name="AppInitial"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Text="{Binding Initial}" />
                            <Image x:Name="AppIcon"
                                   Width="24"
                                   Height="24"
                                   Source="{Binding Icon}"
                                   Stretch="Uniform" />
                            <TextBlock x:Name="FolderIcon"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       Foreground="#F4C242"
                                       Text="&#xE8B7;"
                                       Visibility="Collapsed" />
                        </Grid>
                        <TextBlock Grid.Column="1"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Text="{Binding Name}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="FolderChevron"
                                   Grid.Column="2"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="11"
                                   Text="{Binding FolderChevron}"
                                   Visibility="Collapsed" />
                    </Grid>
                </Button>
                <ItemsControl Margin="20,0,0,0"
                              ItemsSource="{Binding Children}"
                              ItemTemplate="{DynamicResource AppEntryTemplate}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                </ItemsControl>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                    <Setter TargetName="AppInitial" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="AppIcon" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="FolderIcon" Property="Visibility" Value="Visible" />
                    <Setter TargetName="FolderChevron" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource MenuBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48" />
            <ColumnDefinition Width="204" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Button Grid.Row="0" Style="{StaticResource RailButtonStyle}" Content="&#xE700;" ToolTip="展开" />
            <StackPanel Grid.Row="2">
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xE77B;" ToolTip="用户" />
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xE8A5;" ToolTip="文档" />
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xEB9F;" ToolTip="图片" />
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xE713;" ToolTip="设置" />
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xE7E8;" ToolTip="电源" />
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="SearchPanel"
                    Margin="8,8,8,4"
                    Height="36"
                    Background="#2D2D2D"
                    BorderBrush="#707070"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Text="&#xE721;" />
                    <TextBox x:Name="SearchBox"
                             Grid.Column="1"
                             Padding="0,7,4,0"
                             Foreground="White"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="Segoe UI"
                             FontSize="14"
                             TextChanged="SearchBox_TextChanged" />
                </Grid>
            </Border>

            <ScrollViewer x:Name="AppsScrollViewer"
                          Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Hidden">
                <StackPanel Margin="8,20,8,16">
                    <StackPanel x:Name="RecentPanel">
                        <TextBlock Height="28" Margin="8,0,0,0" FontSize="14" Text="最近添加" />
                        <ItemsControl ItemsSource="{Binding RecentApps}" ItemTemplate="{StaticResource AppEntryTemplate}" />
                        <TextBlock Height="32"
                                   Margin="8,4,0,0"
                                   Foreground="{StaticResource SubtleText}"
                                   FontSize="13"
                                   Text="展开⌄" />
                    </StackPanel>

                    <ItemsControl x:Name="AppsList"
                                  ItemsSource="{Binding AppsView}"
                                  ItemTemplate="{StaticResource AppEntryTemplate}">
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource LetterHeaderStyle}"
                                                Tag="{Binding Name}"
                                                Content="{Binding Name}"
                                                Click="LetterHeader_Click" />
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="LetterIndexPanel"
                    Grid.RowSpan="2"
                    Margin="8"
                    Padding="8"
                    Background="#F02A2A2A"
                    Visibility="Collapsed"
                    Panel.ZIndex="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Text="选择字母" />
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding AlphabetLetters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="6" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:AlphabetIndexEntry}">
                                <Button Style="{StaticResource AlphabetButtonStyle}"
                                        Tag="{Binding}"
                                        Content="{Binding Label}"
                                        IsEnabled="{Binding IsAvailable}"
                                        Click="AlphabetLetter_Click" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="2">
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="新建自定义磁贴…" Click="AddCommandTile_Click" />
                </ContextMenu>
            </Border.ContextMenu>
            <ScrollViewer Margin="28,28,0,0"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Hidden">
                <ItemsControl Margin="0,0,12,20" ItemsSource="{Binding TileLayout.Groups}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel ItemWidth="{x:Static local:Win10TileMetrics.GroupPitch}"
                                       Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:TileGroup}">
                            <StackPanel Width="{x:Static local:Win10TileMetrics.GroupWidth}"
                                        Margin="0,0,16,24">
                                <TextBlock Height="28"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           Text="{Binding Name}" />
                                <ItemsControl Width="{x:Static local:Win10TileMetrics.GroupWidth}"
                                              Height="{Binding PixelHeight}"
                                              AllowDrop="True"
                                              ItemsSource="{Binding Tiles}"
                                              Tag="{Binding}"
                                              DragOver="TileGroup_DragOver"
                                              Drop="TileGroup_Drop">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:TileItem}">
                                            <Button Width="{Binding PixelWidth}"
                                                    Height="{Binding PixelHeight}"
                                                    Style="{StaticResource TileStyle}"
                                                    Tag="{Binding}"
                                                    Click="TileButton_Click"
                                                    PreviewMouseLeftButtonDown="TileButton_PreviewMouseLeftButtonDown"
                                                    PreviewMouseMove="TileButton_PreviewMouseMove">
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="磁贴设置…" Click="TileSettings_Click" />
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                                <Grid>
                                                    <TextBlock x:Name="TileInitial"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="24"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding Initial}" />
                                                    <Image x:Name="TileIcon"
                                                           Width="32"
                                                           Height="32"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Source="{Binding Icon}"
                                                           Stretch="Uniform" />
                                                    <TextBlock x:Name="TileTitle"
                                                               VerticalAlignment="Bottom"
                                                               FontSize="12"
                                                               LineHeight="14"
                                                               MaxHeight="30"
                                                               Text="{Binding Name}"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextWrapping="Wrap" />
                                                </Grid>
                                            </Button>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Size}" Value="Small">
                                                    <Setter TargetName="TileIcon" Property="Width" Value="24" />
                                                    <Setter TargetName="TileIcon" Property="Height" Value="24" />
                                                    <Setter TargetName="TileTitle" Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Size}" Value="Large">
                                                    <Setter TargetName="TileIcon" Property="Width" Value="44" />
                                                    <Setter TargetName="TileIcon" Property="Height" Value="44" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border Height="7"
                VerticalAlignment="Top"
                Background="Transparent"
                Cursor="SizeNS"
                Panel.ZIndex="10"
                MouseLeftButtonDown="TopResizeBorder_MouseLeftButtonDown" />
        <Border Width="7"
                HorizontalAlignment="Right"
                Background="Transparent"
                Cursor="SizeWE"
                Panel.ZIndex="10"
                MouseLeftButtonDown="RightResizeBorder_MouseLeftButtonDown" />
        <Border Width="14"
                Height="14"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="Transparent"
                Cursor="SizeNESW"
                Panel.ZIndex="11"
                MouseLeftButtonDown="TopRightResizeBorder_MouseLeftButtonDown" />
    </Grid>
</Window>
