<Window x:Class="TileStart.Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="TileStart"
        Width="1624"
        Height="720"
        MinWidth="720"
        MinHeight="480"
        Background="#CC202020"
        BorderBrush="#4A4A4A"
        BorderThickness="1"
        FontFamily="Segoe UI"
        Foreground="White"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        Topmost="True"
        UseLayoutRounding="True"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewTextInput="Window_PreviewTextInput">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="MenuBackground" Color="#CC202020" />
        <SolidColorBrush x:Key="RailBackground" Color="#D0181818" />
        <SolidColorBrush x:Key="HoverBackground" Color="#3A3A3A" />
        <SolidColorBrush x:Key="TileBackground" Color="#353535" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D7" />

        <Style x:Key="RailButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource HoverBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppRowStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource HoverBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TileStyle" TargetType="Button">
            <Setter Property="Width" Value="100" />
            <Setter Property="Height" Value="100" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource TileBackground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TileBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TileBorder" Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="AppEntryTemplate">
            <Button Style="{StaticResource AppRowStyle}" Tag="{Binding}" Click="AppButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" Background="#3B3B3B">
                        <Grid>
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Text="{Binding Initial}" />
                            <Image Width="28" Height="28" Source="{Binding Icon}" Stretch="Uniform" />
                        </Grid>
                    </Border>
                    <TextBlock Grid.Column="1" Margin="10,0" VerticalAlignment="Center" FontSize="14" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                </Grid>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource MenuBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48" />
            <ColumnDefinition Width="276" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource RailBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Button Grid.Row="0" Style="{StaticResource RailButtonStyle}" Content="&#xE700;" ToolTip="展开" />
            <StackPanel Grid.Row="2">
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xE77B;" ToolTip="用户" />
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xE8A5;" ToolTip="文档" />
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xEB9F;" ToolTip="图片" />
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xE713;" ToolTip="设置" />
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xE7E8;" ToolTip="电源" />
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="SearchPanel" Margin="8,10,8,4" Background="#2D2D2D" BorderBrush="#666666" BorderThickness="1" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="36" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xE721;" />
                    <TextBox x:Name="SearchBox" Grid.Column="1" Height="34" Padding="0,6" Foreground="White" Background="Transparent" BorderThickness="0" FontFamily="Segoe UI" FontSize="14" TextChanged="SearchBox_TextChanged" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="8,18,8,18">
                    <StackPanel x:Name="RecentPanel">
                        <TextBlock Margin="8,0,0,8" FontSize="14" Text="最近添加" />
                        <ItemsControl ItemsSource="{Binding RecentApps}" ItemTemplate="{StaticResource AppEntryTemplate}" />
                        <TextBlock Margin="8,8,0,8" Foreground="#E0E0E0" FontSize="13" Text="展开⌄" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding AppsView}" ItemTemplate="{StaticResource AppEntryTemplate}">
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="8,10,0,4" FontSize="14" Text="{Binding Name}" />
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Column="2" BorderBrush="#2B2B2B" BorderThickness="1,0,0,0">
            <ScrollViewer Margin="0,48,0,0"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,18,18" Orientation="Horizontal">
                    <WrapPanel Width="416" Margin="0,0,16,0" HorizontalAlignment="Left">
                        <Button Style="{StaticResource TileStyle}" Background="#343434"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="29" Text="&#xE8BD;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="微信" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="28" FontWeight="SemiBold" Text="Q" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="QQ" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="29" Text="&#xE8F2;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="企业微信" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}" Background="#3A3A3A"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="30" Text="&#xE8D6;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="QQ音乐" /></Grid></Button>

                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="27" Text="&#xE756;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="MobaXterm" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="23" FontWeight="SemiBold" Text="VS" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="Visual Studio Code" TextWrapping="Wrap" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="23" FontWeight="SemiBold" Text="DG" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="DataGrip" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="30" Text="&#xE8A1;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="Outlook" /></Grid></Button>

                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold" Text="IJ" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="IntelliJ IDEA" TextWrapping="Wrap" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold" Text="WS" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="WebStorm" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold" Text="PC" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="PyCharm" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="30" Text="&#xE8EF;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="计算器" /></Grid></Button>

                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="30" Text="&#xE713;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="Watt Toolkit" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="30" Text="&#xE768;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="雷神加速器" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="28" Text="&#xE8B9;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="DSX" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="28" Text="&#xE7FC;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="游戏加加" /></Grid></Button>
                    </WrapPanel>

                    <WrapPanel Width="416" Margin="0,0,16,0" HorizontalAlignment="Left">
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="28" Text="&#xE9D9;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="HWiNFO64" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" FontWeight="SemiBold" Text="3D" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="3DMark" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="28" FontWeight="Bold" Text="64" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="AIDA64" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="28" Text="&#xE7C3;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="图吧工具箱" /></Grid></Button>

                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold" Text="PW" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="完美世界竞技平台" TextWrapping="Wrap" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold" Text="5E" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="5E 对战平台" TextWrapping="Wrap" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="30" Text="&#xE7FC;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="Steam" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold" Text="EPIC" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="Epic Games" /></Grid></Button>

                        <Button Style="{StaticResource TileStyle}" Background="#555555"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold" Text="WG" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="WeGame" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold" Text="Mu" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="MuMu模拟器" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="30" Text="&#xE8D7;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="战网" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}" Background="#4A3368"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="30" Text="&#xE8B9;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="游戏库" /></Grid></Button>

                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="28" Text="&#xE8A5;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="BilibiliDown" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="28" Text="&#xE753;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="夸克" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="28" Text="&#xE8B7;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="百度网盘" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="28" Text="&#xE9D9;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="ZenTimings" /></Grid></Button>
                    </WrapPanel>

                    <WrapPanel Width="416" HorizontalAlignment="Left">
                        <Button Width="204" Height="204" Style="{StaticResource TileStyle}" Background="#31506A"><Grid><TextBlock Margin="4" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="24" Text="23°" /><TextBlock Margin="4,38,4,0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="13" Text="大雾 · 橙色预警" /><TextBlock Margin="4" VerticalAlignment="Bottom" FontSize="12" Text="天气" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="30" Text="&#xE9F9;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="Windows On Top" TextWrapping="Wrap" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="30" Text="&#xE74D;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="回收站" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="30" Text="&#xE823;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="时钟" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="30" Text="&#xE8EF;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="geek" /></Grid></Button>

                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold" Text="CS2" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="Counter-Strike 2" TextWrapping="Wrap" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" FontWeight="SemiBold" Text="V" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="Grand Theft Auto V" TextWrapping="Wrap" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="30" Text="&#xE768;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="Microsoft Store" TextWrapping="Wrap" /></Grid></Button>
                        <Button Style="{StaticResource TileStyle}"><Grid><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="30" Text="&#xE8A5;" /><TextBlock VerticalAlignment="Bottom" FontSize="12" Text="NVIDIA App" TextWrapping="Wrap" /></Grid></Button>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Height="7"
                VerticalAlignment="Top"
                Background="Transparent"
                Cursor="SizeNS"
                Panel.ZIndex="10"
                MouseLeftButtonDown="TopResizeBorder_MouseLeftButtonDown" />
        <Border Width="7"
                HorizontalAlignment="Right"
                Background="Transparent"
                Cursor="SizeWE"
                Panel.ZIndex="10"
                MouseLeftButtonDown="RightResizeBorder_MouseLeftButtonDown" />
        <Border Width="14"
                Height="14"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="Transparent"
                Cursor="SizeNESW"
                Panel.ZIndex="11"
                MouseLeftButtonDown="TopRightResizeBorder_MouseLeftButtonDown" />
    </Grid>
</Window>
