<Window x:Class="TileStart.Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:TileStart.Host"
        Title="TileStart"
        Width="1624"
        Height="720"
        MinWidth="720"
        MinHeight="480"
        Background="#CC202020"
        BorderBrush="#4A4A4A"
        BorderThickness="1"
        FontFamily="Segoe UI"
        Foreground="White"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        Topmost="True"
        UseLayoutRounding="True"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewTextInput="Window_PreviewTextInput">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="MenuBackground" Color="#CC202020" />
        <SolidColorBrush x:Key="RailBackground" Color="#D0181818" />
        <SolidColorBrush x:Key="HoverBackground" Color="#3A3A3A" />
        <SolidColorBrush x:Key="TileBackground" Color="#353535" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D7" />

        <Style x:Key="RailButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource HoverBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppRowStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource HoverBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TileStyle" TargetType="Button">
            <Setter Property="Width" Value="100" />
            <Setter Property="Height" Value="100" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource TileBackground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TileBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TileBorder" Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="AppEntryTemplate">
            <Button Style="{StaticResource AppRowStyle}" Tag="{Binding}" Click="AppButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" Background="#3B3B3B">
                        <Grid>
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Text="{Binding Initial}" />
                            <Image Width="28" Height="28" Source="{Binding Icon}" Stretch="Uniform" />
                        </Grid>
                    </Border>
                    <TextBlock Grid.Column="1" Margin="10,0" VerticalAlignment="Center" FontSize="14" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                </Grid>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource MenuBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48" />
            <ColumnDefinition Width="276" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource RailBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Button Grid.Row="0" Style="{StaticResource RailButtonStyle}" Content="&#xE700;" ToolTip="展开" />
            <StackPanel Grid.Row="2">
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xE77B;" ToolTip="用户" />
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xE8A5;" ToolTip="文档" />
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xEB9F;" ToolTip="图片" />
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xE713;" ToolTip="设置" />
                <Button Style="{StaticResource RailButtonStyle}" Content="&#xE7E8;" ToolTip="电源" />
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="SearchPanel" Margin="8,10,8,4" Background="#2D2D2D" BorderBrush="#666666" BorderThickness="1" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="36" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xE721;" />
                    <TextBox x:Name="SearchBox" Grid.Column="1" Height="34" Padding="0,6" Foreground="White" Background="Transparent" BorderThickness="0" FontFamily="Segoe UI" FontSize="14" TextChanged="SearchBox_TextChanged" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="8,18,8,18">
                    <StackPanel x:Name="RecentPanel">
                        <TextBlock Margin="8,0,0,8" FontSize="14" Text="最近添加" />
                        <ItemsControl ItemsSource="{Binding RecentApps}" ItemTemplate="{StaticResource AppEntryTemplate}" />
                        <TextBlock Margin="8,8,0,8" Foreground="#E0E0E0" FontSize="13" Text="展开⌄" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding AppsView}" ItemTemplate="{StaticResource AppEntryTemplate}">
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="8,10,0,4" FontSize="14" Text="{Binding Name}" />
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Column="2" BorderBrush="#2B2B2B" BorderThickness="1,0,0,0">
            <Grid>
                <Button Margin="16,10,0,0"
                        Padding="12,5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Content="＋ 添加磁贴"
                        Click="AddCommandTile_Click" />
                <ScrollViewer Margin="0,48,0,0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl Margin="0,0,18,18" ItemsSource="{Binding TileLayout.Groups}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel ItemWidth="{x:Static local:Win10TileMetrics.GroupPitch}"
                                           Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:TileGroup}">
                                <StackPanel Width="{x:Static local:Win10TileMetrics.GroupWidth}"
                                            Margin="0,0,16,24">
                                    <TextBlock Height="24" Margin="4,0,0,0" FontSize="14" Text="{Binding Name}" />
                                    <ItemsControl Width="{x:Static local:Win10TileMetrics.GroupWidth}"
                                                  Height="{Binding PixelHeight}"
                                                  AllowDrop="True"
                                                  ItemsSource="{Binding Tiles}"
                                                  Tag="{Binding}"
                                                  DragOver="TileGroup_DragOver"
                                                  Drop="TileGroup_Drop">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                                <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:TileItem}">
                                                <Button Width="{Binding PixelWidth}"
                                                        Height="{Binding PixelHeight}"
                                                        Padding="8"
                                                        Style="{StaticResource TileStyle}"
                                                        Tag="{Binding}"
                                                        Click="TileButton_Click"
                                                        PreviewMouseLeftButtonDown="TileButton_PreviewMouseLeftButtonDown"
                                                        PreviewMouseMove="TileButton_PreviewMouseMove">
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="磁贴设置…" Click="TileSettings_Click" />
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                    <Grid>
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="24"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Initial}" />
                                                        <Image Width="36" Height="36" Source="{Binding Icon}" Stretch="Uniform" />
                                                        <TextBlock VerticalAlignment="Bottom"
                                                                   FontSize="12"
                                                                   Text="{Binding Name}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="Wrap" />
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Height="7"
                VerticalAlignment="Top"
                Background="Transparent"
                Cursor="SizeNS"
                Panel.ZIndex="10"
                MouseLeftButtonDown="TopResizeBorder_MouseLeftButtonDown" />
        <Border Width="7"
                HorizontalAlignment="Right"
                Background="Transparent"
                Cursor="SizeWE"
                Panel.ZIndex="10"
                MouseLeftButtonDown="RightResizeBorder_MouseLeftButtonDown" />
        <Border Width="14"
                Height="14"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="Transparent"
                Cursor="SizeNESW"
                Panel.ZIndex="11"
                MouseLeftButtonDown="TopRightResizeBorder_MouseLeftButtonDown" />
    </Grid>
</Window>
