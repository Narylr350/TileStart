<Window x:Class="TileStart.Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:TileStart.Host"
        Title="TileStart"
        Width="1252"
        Height="768"
        MinWidth="680"
        MinHeight="480"
        Background="Transparent"
        FontFamily="Segoe UI"
        FontSize="14"
        FontWeight="Medium"
        Foreground="White"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        Topmost="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextHintingMode="Fixed"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp"
        PreviewMouseMove="Window_PreviewMouseMove"
        PreviewTextInput="Window_PreviewTextInput">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="TileBackground" Color="#3A3A3A" />
        <SolidColorBrush x:Key="SubtleText" Color="#D9FFFFFF" />
        <SolidColorBrush x:Key="ExpandedNavigationBackground" Color="#EE202020" />

        <Style x:Key="StartVerticalScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="{x:Static local:Win10VisualMetrics.TileScrollBarWidth}" />
            <Setter Property="Margin" Value="{x:Static local:Win10VisualMetrics.TileScrollBarMargin}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Opacity="0"
                                                  Focusable="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="ScrollThumb"
                                           Width="2"
                                           MinHeight="24"
                                           HorizontalAlignment="Right"
                                           Background="#70FFFFFF"
                                           Opacity="0.72">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Opacity="0"
                                                  Focusable="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ScrollThumb" Property="Width" Value="6" />
                                <Setter TargetName="ScrollThumb" Property="Opacity" Value="1" />
                                <Setter TargetName="ScrollThumb" Property="Background" Value="#A8FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TileScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"
                                                    Content="{TemplateBinding Content}"
                                                    ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    Margin="{TemplateBinding Padding}"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       HorizontalAlignment="Right"
                                       Panel.ZIndex="1"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       Orientation="Vertical"
                                       Style="{StaticResource StartVerticalScrollBarStyle}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RailButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="{x:Static local:Win10VisualMetrics.NavigationItemHeight}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <local:Win10InteractionBorder x:Name="Background"
                                                      Background="{TemplateBinding Background}"
                                                      IsPressedState="{Binding IsPressed, RelativeSource={RelativeSource TemplatedParent}}"
                                                      RevealRadius="88">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="{x:Static local:Win10VisualMetrics.CollapsedNavigationGridLength}" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  TextElement.FontFamily="Segoe MDL2 Assets"
                                                  TextElement.FontSize="16"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                                <TextBlock Grid.Column="1"
                                           Margin="12,0,16,0"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontFamily="Segoe UI, Microsoft YaHei UI"
                                           FontSize="14"
                                           Text="{TemplateBinding Tag}"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </local:Win10InteractionBorder>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppRowStyle" TargetType="Button">
            <Setter Property="Height" Value="{x:Static local:Win10VisualMetrics.AllAppsRowHeight}" />
            <Setter Property="Margin" Value="{x:Static local:Win10VisualMetrics.AllAppsItemMargin}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <local:Win10InteractionBorder x:Name="Background"
                                                      Background="{TemplateBinding Background}"
                                                      IsPressedState="{Binding IsPressed, RelativeSource={RelativeSource TemplatedParent}}"
                                                      RevealRadius="104">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </local:Win10InteractionBorder>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TileStyle" TargetType="Button">
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource TileBackground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <local:Win10InteractionBorder x:Name="TileBorder"
                                                      Background="{TemplateBinding Background}"
                                                      HoverFillOpacity="0"
                                                      IsPressedState="{Binding IsPressed, RelativeSource={RelativeSource TemplatedParent}}"
                                                      PressedFillOpacity="0"
                                                      RevealBorderOpacity="0.42"
                                                      RevealRadius="96"
                                                      UsesSharedPointerLight="True"
                                                      SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </local:Win10InteractionBorder>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StartContextMenuStyle" TargetType="ContextMenu">
            <EventSetter Event="Opened" Handler="StartContextMenu_Opened" />
            <EventSetter Event="Closed" Handler="StartContextMenu_Closed" />
            <Setter Property="MinWidth" Value="{x:Static local:Win10VisualMetrics.ContextMenuMinWidth}" />
            <Setter Property="Background" Value="#FC232323" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#171717" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="{x:Static local:Win10VisualMetrics.ContextMenuPresenterPadding}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
            <Setter Property="TextOptions.TextRenderingMode" Value="Grayscale" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border x:Name="ContextMenuPopupBorder"
                                MinWidth="{TemplateBinding MinWidth}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StartMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="{x:Static local:Win10VisualMetrics.ContextMenuItemPadding}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="{x:Static local:Win10VisualMetrics.ContextMenuFontSize}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
            <Setter Property="TextOptions.TextRenderingMode" Value="Grayscale" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid x:Name="MenuItemRoot"
                              Height="{TemplateBinding Height}"
                              Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="CheckColumn" Width="0" />
                                <ColumnDefinition
                                    Width="{x:Static local:Win10VisualMetrics.ContextMenuIconPlaceholderGridLength}" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CheckMark"
                                       Grid.Column="0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Text="&#xE73E;"
                                       Visibility="Collapsed" />
                            <ContentPresenter Grid.Column="1"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Icon}" />
                            <ContentPresenter Grid.Column="2"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True" />
                            <TextBlock x:Name="SubmenuArrow"
                                       Grid.Column="3"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="10"
                                       Text="&#xE76C;"
                                       Visibility="Collapsed" />
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Opened="SubmenuPopup_Opened"
                                   Closed="SubmenuPopup_Closed"
                                   Placement="Right"
                                   PopupAnimation="None">
                                <Border MinWidth="{x:Static local:Win10VisualMetrics.ContextMenuMinWidth}"
                                        Padding="{x:Static local:Win10VisualMetrics.ContextMenuPresenterPadding}"
                                        Background="#FC232323"
                                        BorderBrush="#171717"
                                        BorderThickness="1">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsCheckable" Value="True">
                                <Setter TargetName="CheckColumn"
                                        Property="Width"
                                        Value="{x:Static local:Win10VisualMetrics.ContextMenuCheckPlaceholderGridLength}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemRoot" Property="Background"
                                        Value="{x:Static local:Win10Theme.ContextMenuHighlightBrush}" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="MenuItemRoot" Property="Background"
                                        Value="{x:Static local:Win10Theme.ContextMenuHighlightBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="8,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="#70FFFFFF" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LetterHeaderStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="{x:Static local:Win10VisualMetrics.AllAppsItemMargin}" />
            <Setter Property="Padding" Value="{x:Static local:Win10VisualMetrics.AllAppsGroupHeaderPadding}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Bottom" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="{x:Static local:Win10VisualMetrics.AllAppsGroupHeaderFontSize}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <local:Win10InteractionBorder x:Name="Background"
                                                      Background="{TemplateBinding Background}"
                                                      IsPressedState="{Binding IsPressed, RelativeSource={RelativeSource TemplatedParent}}"
                                                      RevealRadius="84">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </local:Win10InteractionBorder>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AlphabetButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="{x:Static local:Win10VisualMetrics.AlphabetCellSize}" />
            <Setter Property="Height" Value="{x:Static local:Win10VisualMetrics.AlphabetCellSize}" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="{x:Static local:Win10VisualMetrics.AlphabetFontSize}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <local:Win10InteractionBorder x:Name="Background"
                                                      Background="{TemplateBinding Background}"
                                                      IsPressedState="{Binding IsPressed, RelativeSource={RelativeSource TemplatedParent}}"
                                                      RevealRadius="72">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </local:Win10InteractionBorder>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.28" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsGlyph}" Value="True">
                                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="AppEntryTemplate">
            <StackPanel>
                <Button Style="{StaticResource AppRowStyle}"
                        Tag="{Binding}"
                        Click="AppButton_Click"
                        PreviewMouseLeftButtonDown="AppButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="AppButton_PreviewMouseMove">
                    <Button.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}"
                                     Style="{StaticResource StartContextMenuStyle}">
                            <MenuItem Header="固定到“开始”屏幕"
                                      Style="{StaticResource StartMenuItemStyle}"
                                      Click="PinAppToStart_Click">
                                <MenuItem.Icon>
                                    <TextBlock Foreground="White"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="16"
                                               Text="&#xE718;" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="更多">
                                <MenuItem.Style>
                                    <Style TargetType="MenuItem" BasedOn="{StaticResource StartMenuItemStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanOpenFileLocation}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </MenuItem.Style>
                                <MenuItem Header="打开文件所在的位置"
                                          Style="{StaticResource StartMenuItemStyle}"
                                          Click="OpenAppFileLocation_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Foreground="White"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="16"
                                                   Text="&#xE838;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </MenuItem>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                        </Grid.ColumnDefinitions>
                        <Grid Width="{x:Static local:Win10IconMetrics.ClassicAppLogoLayoutSize}"
                              Height="{x:Static local:Win10IconMetrics.ClassicAppLogoLayoutSize}"
                              HorizontalAlignment="Left">
                            <TextBlock x:Name="AppInitial"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Text="{Binding Initial}"
                                       Visibility="Collapsed" />
                            <Image x:Name="AppIcon"
                                   Width="{x:Static local:Win10IconMetrics.ClassicAppLogoImageSize}"
                                   Height="{x:Static local:Win10IconMetrics.ClassicAppLogoImageSize}"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Source="{Binding Icon}"
                                   Stretch="Uniform" />
                        </Grid>
                        <TextBlock Grid.Column="1"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe UI, Microsoft YaHei UI"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Text="{Binding Name}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="FolderChevron"
                                   Grid.Column="2"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="11"
                                   Text="{Binding FolderChevron}"
                                   Visibility="Collapsed" />
                    </Grid>
                </Button>
                <ItemsControl Margin="20,0,0,0"
                              ClipToBounds="True"
                              ItemsSource="{Binding Children}"
                              ItemTemplate="{DynamicResource AppEntryTemplate}"
                              Tag="{Binding}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                </ItemsControl>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                    <Setter TargetName="AppInitial" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                    <Setter TargetName="FolderChevron" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="WindowRoot" Background="Transparent">
        <Grid x:Name="MainSurface" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{x:Static local:Win10VisualMetrics.CollapsedNavigationGridLength}" />
                <ColumnDefinition Width="{x:Static local:Win10VisualMetrics.AllAppsGridLength}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="NavigationPane"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"
                  Width="{x:Static local:Win10VisualMetrics.CollapsedNavigationWidth}"
                  HorizontalAlignment="Left"
                  Background="Transparent"
                  MouseLeave="NavigationPane_MouseLeave"
                  Panel.ZIndex="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="{x:Static local:Win10VisualMetrics.NavigationItemGridLength}" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Button x:Name="NavigationToggleButton"
                        Grid.Row="0"
                        Style="{StaticResource RailButtonStyle}"
                        Content="&#xE700;"
                        Tag="开始"
                        ToolTip="展开"
                        MouseEnter="NavigationToggleButton_MouseEnter"
                        Click="NavigationToggleButton_Click">
                    <Button.ContextMenu>
                        <ContextMenu Style="{StaticResource StartContextMenuStyle}"
                                     Opened="NavigationPreferencesMenu_Opened">
                            <MenuItem Header="用户" Tag="ShowUser" IsCheckable="True"
                                      Style="{StaticResource StartMenuItemStyle}"
                                      Click="NavigationPreference_Click" />
                            <MenuItem Header="文档" Tag="ShowDocuments" IsCheckable="True"
                                      Style="{StaticResource StartMenuItemStyle}"
                                      Click="NavigationPreference_Click" />
                            <MenuItem Header="下载" Tag="ShowDownloads" IsCheckable="True"
                                      Style="{StaticResource StartMenuItemStyle}"
                                      Click="NavigationPreference_Click" />
                            <MenuItem Header="图片" Tag="ShowPictures" IsCheckable="True"
                                      Style="{StaticResource StartMenuItemStyle}"
                                      Click="NavigationPreference_Click" />
                            <MenuItem Header="音乐" Tag="ShowMusic" IsCheckable="True"
                                      Style="{StaticResource StartMenuItemStyle}"
                                      Click="NavigationPreference_Click" />
                            <MenuItem Header="视频" Tag="ShowVideos" IsCheckable="True"
                                      Style="{StaticResource StartMenuItemStyle}"
                                      Click="NavigationPreference_Click" />
                            <MenuItem Header="文件资源管理器" Tag="ShowFileExplorer" IsCheckable="True"
                                      Style="{StaticResource StartMenuItemStyle}"
                                      Click="NavigationPreference_Click" />
                            <MenuItem Header="网络" Tag="ShowNetwork" IsCheckable="True"
                                      Style="{StaticResource StartMenuItemStyle}"
                                      Click="NavigationPreference_Click" />
                            <MenuItem Header="设置" Tag="ShowSettings" IsCheckable="True"
                                      Style="{StaticResource StartMenuItemStyle}"
                                      Click="NavigationPreference_Click" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <StackPanel Grid.Row="2">
                    <Button x:Name="UserNavigationButton"
                            Style="{StaticResource RailButtonStyle}"
                            Tag="{Binding CurrentUserName}"
                            ToolTip="用户"
                            Click="UserNavigationButton_Click">
                        <Button.Content>
                            <Grid Width="{x:Static local:Win10VisualMetrics.NavigationUserPictureSize}"
                                  Height="{x:Static local:Win10VisualMetrics.NavigationUserPictureSize}">
                                <Ellipse Fill="#5A5A5A" />
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Text="&#xE77B;" />
                                <Ellipse>
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding CurrentUserPicture}"
                                                    Stretch="UniformToFill" />
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Grid>
                        </Button.Content>
                        <Button.ContextMenu>
                            <ContextMenu Style="{StaticResource StartContextMenuStyle}"
                                         Opened="StartContextMenu_Opened"
                                         Closed="StartContextMenu_Closed">
                                <MenuItem Header="更改账户设置" Style="{StaticResource StartMenuItemStyle}"
                                          Click="AccountSettings_Click" />
                                <MenuItem Header="锁定" Style="{StaticResource StartMenuItemStyle}"
                                          Click="LockSession_Click" />
                                <MenuItem Header="注销" Style="{StaticResource StartMenuItemStyle}" Click="SignOut_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="DocumentsNavigationButton"
                            Style="{StaticResource RailButtonStyle}"
                            Content="&#xE8A5;"
                            Tag="文档"
                            ToolTip="文档"
                            Click="DocumentsNavigationButton_Click" />
                    <Button x:Name="DownloadsNavigationButton"
                            Style="{StaticResource RailButtonStyle}"
                            Content="&#xE896;"
                            Tag="下载"
                            ToolTip="下载"
                            Click="DownloadsNavigationButton_Click" />
                    <Button x:Name="PicturesNavigationButton"
                            Style="{StaticResource RailButtonStyle}"
                            Content="&#xEB9F;"
                            Tag="图片"
                            ToolTip="图片"
                            Click="PicturesNavigationButton_Click" />
                    <Button x:Name="MusicNavigationButton"
                            Style="{StaticResource RailButtonStyle}"
                            Content="&#xE8D6;"
                            Tag="音乐"
                            ToolTip="音乐"
                            Click="MusicNavigationButton_Click" />
                    <Button x:Name="VideosNavigationButton"
                            Style="{StaticResource RailButtonStyle}"
                            Content="&#xE714;"
                            Tag="视频"
                            ToolTip="视频"
                            Click="VideosNavigationButton_Click" />
                    <Button x:Name="FileExplorerNavigationButton"
                            Style="{StaticResource RailButtonStyle}"
                            Content="&#xE838;"
                            Tag="文件资源管理器"
                            ToolTip="文件资源管理器"
                            Click="FileExplorerNavigationButton_Click" />
                    <Button x:Name="NetworkNavigationButton"
                            Style="{StaticResource RailButtonStyle}"
                            Content="&#xE968;"
                            Tag="网络"
                            ToolTip="网络"
                            Click="NetworkNavigationButton_Click" />
                    <Button x:Name="SettingsNavigationButton"
                            Style="{StaticResource RailButtonStyle}"
                            Content="&#xE713;"
                            Tag="设置"
                            ToolTip="设置"
                            Click="SettingsNavigationButton_Click" />
                    <Button x:Name="PowerNavigationButton"
                            Style="{StaticResource RailButtonStyle}"
                            Content="&#xE7E8;"
                            Tag="电源"
                            ToolTip="电源"
                            Click="PowerNavigationButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu Style="{StaticResource StartContextMenuStyle}"
                                         Opened="StartContextMenu_Opened"
                                         Closed="StartContextMenu_Closed">
                                <MenuItem Header="睡眠" Style="{StaticResource StartMenuItemStyle}" Click="Sleep_Click" />
                                <MenuItem Header="关机" Style="{StaticResource StartMenuItemStyle}"
                                          Click="ShutDown_Click" />
                                <MenuItem Header="重启" Style="{StaticResource StartMenuItemStyle}" Click="Restart_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="SearchPanel"
                        Margin="8,8,8,4"
                        Height="36"
                        Background="#2D2D2D"
                        BorderBrush="#707070"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Text="&#xE721;" />
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 Padding="0,7,4,0"
                                 Foreground="White"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontFamily="Segoe UI"
                                 FontSize="14"
                                 TextChanged="SearchBox_TextChanged" />
                    </Grid>
                </Border>

                <Grid x:Name="SemanticZoomViewport"
                      Grid.Row="1"
                      ClipToBounds="True">
                    <Grid x:Name="SemanticZoomSurface">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="SemanticZoomSharedScale"
                                                ScaleX="2"
                                                ScaleY="2" />
                                <TranslateTransform x:Name="SemanticZoomSharedTranslate" />
                            </TransformGroup>
                        </Grid.RenderTransform>

                        <Grid x:Name="ZoomedInPresenter">
                            <Grid.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="SemanticZoomedInScale"
                                                    ScaleX="0.5"
                                                    ScaleY="0.5" />
                                    <TranslateTransform x:Name="SemanticZoomedInTranslate" />
                                </TransformGroup>
                            </Grid.RenderTransform>

                            <ScrollViewer x:Name="AppsScrollViewer"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar"
                                           BasedOn="{StaticResource StartVerticalScrollBarStyle}" />
                                </ScrollViewer.Resources>
                                <StackPanel Margin="{x:Static local:Win10VisualMetrics.AllAppsListPadding}">
                                    <StackPanel x:Name="RecentPanel">
                                        <TextBlock
                                            Height="{x:Static local:Win10VisualMetrics.AllAppsGroupHeaderHeight}"
                                            Margin="{x:Static local:Win10VisualMetrics.AllAppsItemMargin}"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Text="最近添加" />
                                        <ItemsControl ItemsSource="{Binding RecentApps}"
                                                      ItemTemplate="{StaticResource AppEntryTemplate}" />
                                        <Button x:Name="RecentExpandButton"
                                                Style="{StaticResource AppRowStyle}"
                                                HorizontalContentAlignment="Left"
                                                Click="RecentExpandButton_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="RecentExpandText"
                                                           VerticalAlignment="Center"
                                                           FontSize="14"
                                                           Text="展开" />
                                                <TextBlock x:Name="RecentExpandGlyph"
                                                           Margin="4,0"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="8"
                                                           Text="&#xE70D;" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <ItemsControl x:Name="AppsList"
                                                  ItemsSource="{Binding AppsView}"
                                                  ItemTemplate="{StaticResource AppEntryTemplate}">
                                        <ItemsControl.GroupStyle>
                                            <GroupStyle>
                                                <GroupStyle.HeaderTemplate>
                                                    <DataTemplate>
                                                        <Button Style="{StaticResource LetterHeaderStyle}"
                                                                Tag="{Binding Name}"
                                                                Content="{Binding Name}"
                                                                Click="LetterHeader_Click" />
                                                    </DataTemplate>
                                                </GroupStyle.HeaderTemplate>
                                            </GroupStyle>
                                        </ItemsControl.GroupStyle>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Border x:Name="LetterIndexPanel"
                                Panel.ZIndex="5"
                                Background="Transparent"
                                IsHitTestVisible="False"
                                Opacity="0"
                                Visibility="Collapsed">
                            <ItemsControl Width="208"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          ItemsSource="{Binding AlphabetLetters}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Width="208" Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:AlphabetIndexEntry}">
                                        <Button Style="{StaticResource AlphabetButtonStyle}"
                                                Tag="{Binding}"
                                                Content="{Binding Label}"
                                                IsEnabled="{Binding IsAvailable}"
                                                Click="AlphabetLetter_Click" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Border x:Name="TilePane"
                    Grid.Column="2"
                    Background="Transparent"
                    AllowDrop="True"
                    DragOver="TileArea_DragOver"
                    Drop="TileArea_Drop">
                <Border.ContextMenu>
                    <ContextMenu Opened="StartContextMenu_Opened" Closed="StartContextMenu_Closed">
                        <MenuItem Header="新建自定义磁贴…" Click="AddCommandTile_Click" />
                    </ContextMenu>
                </Border.ContextMenu>
                <ScrollViewer x:Name="TileScrollViewer"
                              Margin="{x:Static local:Win10VisualMetrics.TileScrollViewerMargin}"
                              Style="{StaticResource TileScrollViewerStyle}">
                    <ItemsControl x:Name="TileGroupsControl"
                                  Margin="0,0,0,20"
                                  ItemsSource="{Binding TileLayout.Groups}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <local:Win10GroupWrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:TileGroup}">
                                <StackPanel Width="{x:Static local:Win10VisualMetrics.TileGroupVisualWidth}"
                                            Margin="0,0,0,24">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu Opened="StartContextMenu_Opened" Closed="StartContextMenu_Closed">
                                            <MenuItem Header="删除组" Click="DeleteGroup_Click" />
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <local:TileGroupHeader
                                        Margin="{x:Static local:Win10VisualMetrics.TileGroupHeaderMargin}"
                                        NameCommitted="GroupHeader_NameCommitted"
                                        PreviewMouseLeftButtonDown="GroupHeader_PreviewMouseLeftButtonDown"
                                        PreviewMouseMove="GroupHeader_PreviewMouseMove"
                                        PreviewMouseLeftButtonUp="GroupHeader_PreviewMouseLeftButtonUp"
                                        LostMouseCapture="GroupHeader_LostMouseCapture" />
                                    <Canvas Width="{x:Static local:Win10TileMetrics.GroupWidth}"
                                            Height="{Binding PixelHeight}"
                                            Margin="{x:Static local:Win10VisualMetrics.TileGroupTilesMargin}">
                                        <ItemsControl Width="{x:Static local:Win10TileMetrics.GroupWidth}"
                                                      Height="{Binding PixelHeight}"
                                                      AllowDrop="True"
                                                      ItemsSource="{Binding Tiles}"
                                                      Tag="{Binding}"
                                                      DragOver="TileGroup_DragOver"
                                                      Drop="TileGroup_Drop">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                                    <Setter Property="Canvas.Top" Value="{Binding DisplayTop}" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type local:TileItem}">
                                                    <Button x:Name="TileButton"
                                                            Width="{Binding PixelWidth}"
                                                            Height="{Binding PixelHeight}"
                                                            Background="{Binding BackgroundBrush}"
                                                            Foreground="{Binding ForegroundBrush}"
                                                            Style="{StaticResource TileStyle}"
                                                            Tag="{Binding}"
                                                            Click="TileButton_Click"
                                                            PreviewMouseLeftButtonDown="TileButton_PreviewMouseLeftButtonDown">
                                                        <Button.ContextMenu>
                                                            <ContextMenu Style="{StaticResource StartContextMenuStyle}">
                                                                <ContextMenu.Resources>
                                                                    <SolidColorBrush
                                                                        x:Key="{x:Static SystemColors.MenuBrushKey}"
                                                                        Color="#2B2B2B" />
                                                                    <SolidColorBrush
                                                                        x:Key="{x:Static SystemColors.MenuTextBrushKey}"
                                                                        Color="White" />
                                                                    <SolidColorBrush
                                                                        x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                                                        Color="#505050" />
                                                                    <SolidColorBrush
                                                                        x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                                                        Color="White" />
                                                                </ContextMenu.Resources>
                                                                <MenuItem Header="从“开始”屏幕取消固定"
                                                                          Style="{StaticResource StartMenuItemStyle}"
                                                                          Click="UnpinTile_Click">
                                                                    <MenuItem.Icon>
                                                                        <TextBlock Foreground="White"
                                                                                FontFamily="Segoe MDL2 Assets"
                                                                                FontSize="16"
                                                                                Text="&#xE77A;" />
                                                                    </MenuItem.Icon>
                                                                </MenuItem>
                                                                <MenuItem Header="解散文件夹"
                                                                          Tag="DissolveFolder"
                                                                          Visibility="Collapsed"
                                                                          Style="{StaticResource StartMenuItemStyle}"
                                                                          Click="DissolveFolder_Click" />
                                                                <MenuItem Header="调整大小"
                                                                          Style="{StaticResource StartMenuItemStyle}">
                                                                    <MenuItem Header="小"
                                                                              Tag="Small"
                                                                              IsCheckable="True"
                                                                              Style="{StaticResource StartMenuItemStyle}"
                                                                              Click="ResizeTile_Click">
                                                                        <MenuItem.Icon>
                                                                            <Border Width="13" Height="13"
                                                                                    BorderBrush="White"
                                                                                    BorderThickness="1.5" />
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                    <MenuItem Header="中"
                                                                              Tag="Medium"
                                                                              IsCheckable="True"
                                                                              Style="{StaticResource StartMenuItemStyle}"
                                                                              Click="ResizeTile_Click">
                                                                        <MenuItem.Icon>
                                                                            <Border Width="16" Height="16"
                                                                                    BorderBrush="White"
                                                                                    BorderThickness="1.5" />
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                    <MenuItem Header="宽"
                                                                              Tag="Wide"
                                                                              IsCheckable="True"
                                                                              Style="{StaticResource StartMenuItemStyle}"
                                                                              Click="ResizeTile_Click">
                                                                        <MenuItem.Icon>
                                                                            <Border Width="18" Height="10"
                                                                                    BorderBrush="White"
                                                                                    BorderThickness="1.5" />
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                    <MenuItem Header="大"
                                                                              Tag="Large"
                                                                              IsCheckable="True"
                                                                              Style="{StaticResource StartMenuItemStyle}"
                                                                              Click="ResizeTile_Click">
                                                                        <MenuItem.Icon>
                                                                            <Border Width="16" Height="16"
                                                                                    Background="White" />
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                </MenuItem>
                                                                <MenuItem Header="更多"
                                                                          Style="{StaticResource StartMenuItemStyle}">
                                                                    <MenuItem Header="打开文件所在的位置"
                                                                              Tag="OpenFileLocation"
                                                                              Style="{StaticResource StartMenuItemStyle}"
                                                                              Click="OpenTileFileLocation_Click">
                                                                        <MenuItem.Icon>
                                                                            <TextBlock Foreground="White"
                                                                                    FontFamily="Segoe MDL2 Assets"
                                                                                    FontSize="16"
                                                                                    Text="&#xE838;" />
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                    <MenuItem Header="以管理员身份运行"
                                                                              Style="{StaticResource StartMenuItemStyle}"
                                                                              Click="RunTileAsAdministrator_Click">
                                                                        <MenuItem.Icon>
                                                                            <TextBlock Foreground="White"
                                                                                    FontFamily="Segoe MDL2 Assets"
                                                                                    FontSize="16"
                                                                                    Text="&#xE83D;" />
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                </MenuItem>
                                                                <Separator />
                                                                <MenuItem Header="TileStart 设置…"
                                                                          Style="{StaticResource StartMenuItemStyle}"
                                                                          Click="TileSettings_Click">
                                                                    <MenuItem.Icon>
                                                                        <TextBlock Foreground="White"
                                                                                FontFamily="Segoe MDL2 Assets"
                                                                                FontSize="16"
                                                                                Text="&#xE713;" />
                                                                    </MenuItem.Icon>
                                                                </MenuItem>
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                        <Grid ClipToBounds="True">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition />
                                                                <RowDefinition
                                                                    Height="{x:Static local:Win10VisualMetrics.TileReservedBrandingGridLength}" />
                                                            </Grid.RowDefinitions>
                                                            <Image Grid.RowSpan="2"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                                   Source="{Binding BackgroundImage}"
                                                                   Stretch="UniformToFill" />
                                                            <TextBlock x:Name="TileInitial"
                                                                       Grid.Row="0"
                                                                       Grid.RowSpan="2"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="24"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Initial}"
                                                                       Visibility="Collapsed" />
                                                            <Image x:Name="TileIcon"
                                                                   Grid.Row="0"
                                                                   Grid.RowSpan="2"
                                                                   Width="{Binding IconSize}"
                                                                   Height="{Binding IconSize}"
                                                                   Margin="8"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                                   Source="{Binding Icon}"
                                                                   Stretch="Uniform">
                                                                <Image.RenderTransform>
                                                                    <TranslateTransform
                                                                        Y="{x:Static local:Win10VisualMetrics.TileLogoVerticalOffset}" />
                                                                </Image.RenderTransform>
                                                            </Image>
                                                            <ItemsControl x:Name="FolderPreview"
                                                                          Grid.Row="0"
                                                                          Grid.RowSpan="2"
                                                                          Width="52"
                                                                          Height="52"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          ClipToBounds="True"
                                                                          ItemsSource="{Binding FolderTiles}"
                                                                          Visibility="Collapsed">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <UniformGrid Columns="2" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Margin="1"
                                                                                Background="{Binding BackgroundBrush}">
                                                                            <Image Margin="3"
                                                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                                                    Source="{Binding Icon}"
                                                                                    Stretch="Uniform" />
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <Grid x:Name="TileBranding"
                                                                  Grid.Row="1"
                                                                  Margin="{x:Static local:Win10VisualMetrics.TileBrandingMargin}">
                                                                <TextBlock x:Name="TileTitle"
                                                                           HorizontalAlignment="Left"
                                                                           VerticalAlignment="Bottom"
                                                                           FontFamily="Segoe UI, Microsoft YaHei UI"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding Name}"
                                                                           TextAlignment="Left"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           TextWrapping="NoWrap" />
                                                            </Grid>
                                                            <Grid x:Name="FolderDropCue"
                                                                  Grid.Row="0"
                                                                  Grid.RowSpan="2"
                                                                  Background="#52000000"
                                                                  IsHitTestVisible="False"
                                                                  Visibility="Collapsed">
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontFamily="Segoe MDL2 Assets"
                                                                           FontSize="24"
                                                                           Foreground="White"
                                                                           Text="&#xE8B7;" />
                                                            </Grid>
                                                        </Grid>
                                                    </Button>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                            <Setter TargetName="TileInitial" Property="Visibility"
                                                                    Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsTileFolder}" Value="True">
                                                            <Setter TargetName="TileInitial" Property="Visibility"
                                                                    Value="Collapsed" />
                                                            <Setter TargetName="TileIcon" Property="Visibility"
                                                                    Value="Collapsed" />
                                                            <Setter TargetName="FolderPreview" Property="Visibility"
                                                                    Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                                            <Setter TargetName="TileButton" Property="Opacity"
                                                                    Value="0.24" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsFolderDropTarget}"
                                                                     Value="True">
                                                            <Setter TargetName="FolderDropCue" Property="Visibility"
                                                                    Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Size}" Value="Small">
                                                            <Setter TargetName="TileBranding" Property="Visibility"
                                                                    Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ShowTitle}" Value="False">
                                                            <Setter TargetName="TileTitle" Property="Visibility"
                                                                    Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding UsesFullTileLogo}" Value="True">
                                                            <Setter TargetName="TileIcon" Property="Width" Value="Auto" />
                                                            <Setter TargetName="TileIcon" Property="Height"
                                                                    Value="Auto" />
                                                            <Setter TargetName="TileIcon" Property="Margin" Value="0" />
                                                            <Setter TargetName="TileIcon" Property="Stretch"
                                                                    Value="Fill" />
                                                            <Setter TargetName="TileIcon" Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <TranslateTransform Y="0" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IconPosition}" Value="TopLeft">
                                                            <Setter TargetName="TileIcon"
                                                                    Property="HorizontalAlignment" Value="Left" />
                                                            <Setter TargetName="TileIcon" Property="VerticalAlignment"
                                                                    Value="Top" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IconPosition}" Value="TopRight">
                                                            <Setter TargetName="TileIcon"
                                                                    Property="HorizontalAlignment" Value="Right" />
                                                            <Setter TargetName="TileIcon" Property="VerticalAlignment"
                                                                    Value="Top" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IconPosition}"
                                                                     Value="BottomLeft">
                                                            <Setter TargetName="TileIcon"
                                                                    Property="HorizontalAlignment" Value="Left" />
                                                            <Setter TargetName="TileIcon" Property="VerticalAlignment"
                                                                    Value="Bottom" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IconPosition}"
                                                                     Value="BottomRight">
                                                            <Setter TargetName="TileIcon"
                                                                    Property="HorizontalAlignment" Value="Right" />
                                                            <Setter TargetName="TileIcon" Property="VerticalAlignment"
                                                                    Value="Bottom" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ItemsControl Width="{x:Static local:Win10TileMetrics.GroupWidth}"
                                                      Height="{Binding PixelHeight}"
                                                      Panel.ZIndex="2"
                                                      ItemsSource="{Binding Tiles}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="0" />
                                                    <Setter Property="Canvas.Top" Value="{Binding FolderRegionTop}" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type local:TileItem}">
                                                    <Border x:Name="FolderRegion"
                                                            Width="{x:Static local:Win10TileMetrics.GroupWidth}"
                                                            Height="{Binding FolderRegionHeight}"
                                                            Background="#16000000"
                                                            ClipToBounds="True">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="1" />
                                                                <RowDefinition Height="32" />
                                                                <RowDefinition Height="*" />
                                                                <RowDefinition Height="1" />
                                                                <RowDefinition Height="4" />
                                                            </Grid.RowDefinitions>
                                                            <Border Grid.Row="0" Background="#55FFFFFF" />
                                                            <TextBox Grid.Row="1"
                                                                     MaxLength="500"
                                                                     Padding="0,7,6,0"
                                                                     Foreground="White"
                                                                     Background="Transparent"
                                                                     BorderThickness="0"
                                                                     FontFamily="Segoe UI"
                                                                     FontSize="12"
                                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                            <ItemsControl Grid.Row="2"
                                                                          Width="{x:Static local:Win10TileMetrics.GroupWidth}"
                                                                          Height="{Binding FolderContentHeight}"
                                                                          HorizontalAlignment="Left"
                                                                          VerticalAlignment="Top"
                                                                          AllowDrop="True"
                                                                          ItemsSource="{Binding FolderTiles}"
                                                                          Tag="{Binding}"
                                                                          DragOver="FolderRegion_DragOver"
                                                                          Drop="FolderRegion_Drop">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <Canvas />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemContainerStyle>
                                                                    <Style TargetType="ContentPresenter">
                                                                        <Setter Property="Canvas.Left"
                                                                                Value="{Binding Left}" />
                                                                        <Setter Property="Canvas.Top"
                                                                                Value="{Binding Top}" />
                                                                    </Style>
                                                                </ItemsControl.ItemContainerStyle>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="{x:Type local:TileItem}">
                                                                        <Button Width="{Binding PixelWidth}"
                                                                                Height="{Binding PixelHeight}"
                                                                                Background="{Binding BackgroundBrush}"
                                                                                Foreground="{Binding ForegroundBrush}"
                                                                                Style="{StaticResource TileStyle}"
                                                                                Tag="{Binding}"
                                                                                Click="TileButton_Click"
                                                                                PreviewMouseLeftButtonDown="TileButton_PreviewMouseLeftButtonDown">
                                                                            <Grid ClipToBounds="True">
                                                                                <Image Width="{Binding IconSize}"
                                                                                    Height="{Binding IconSize}"
                                                                                    Margin="8"
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                                                    Source="{Binding Icon}"
                                                                                    Stretch="Uniform" />
                                                                                <TextBlock Margin="8,0,8,5"
                                                                                    HorizontalAlignment="Left"
                                                                                    VerticalAlignment="Bottom"
                                                                                    FontFamily="Segoe UI, Microsoft YaHei UI"
                                                                                    FontSize="12"
                                                                                    FontWeight="SemiBold"
                                                                                    Text="{Binding Name}"
                                                                                    TextTrimming="CharacterEllipsis" />
                                                                            </Grid>
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <Border Grid.Row="3" Background="#55FFFFFF" />
                                                        </Grid>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsFolderExpanded}" Value="False">
                                                            <Setter TargetName="FolderRegion" Property="Visibility"
                                                                    Value="Collapsed" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Canvas x:Name="InternalDragOverlay"
                    Grid.ColumnSpan="3"
                    IsHitTestVisible="False"
                    Panel.ZIndex="20">
                <Image x:Name="InternalDragPreview"
                       Canvas.Left="0"
                       Canvas.Top="0"
                       Opacity="0.96"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Visibility="Collapsed">
                    <Image.RenderTransform>
                        <TranslateTransform x:Name="InternalDragPreviewTransform" />
                    </Image.RenderTransform>
                </Image>
            </Canvas>

            <Border Height="7"
                    Grid.ColumnSpan="3"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    Cursor="SizeNS"
                    Panel.ZIndex="50"
                    MouseLeftButtonDown="TopResizeBorder_MouseLeftButtonDown" />
            <Border Width="7"
                    Grid.ColumnSpan="3"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    Cursor="SizeWE"
                    Panel.ZIndex="50"
                    MouseLeftButtonDown="RightResizeBorder_MouseLeftButtonDown" />
            <Border Width="14"
                    Height="14"
                    Grid.ColumnSpan="3"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    Cursor="SizeNESW"
                    Panel.ZIndex="51"
                    MouseLeftButtonDown="TopRightResizeBorder_MouseLeftButtonDown" />
        </Grid>

        <Image x:Name="EntrancePreview"
               IsHitTestVisible="False"
               Panel.ZIndex="100"
               RenderOptions.BitmapScalingMode="HighQuality"
               SnapsToDevicePixels="True"
               Stretch="Fill"
               Visibility="Collapsed" />
    </Grid>
</Window>